#!/usr/bin/env sh
set -eu

repo="${PLUGIN_LOCK_REPO:-rossnoah/plugin-lock}"
version="${PLUGIN_LOCK_VERSION:-latest}"
install_root="${PLUGIN_LOCK_HOME:-$HOME/.plugin-lock}"
bin_dir="${PLUGIN_LOCK_BIN_DIR:-$HOME/.local/bin}"

fail() {
  printf 'plugin-lock install error: %s\n' "$1" >&2
  exit 1
}

command -v curl >/dev/null 2>&1 || fail "curl is required"
command -v tar >/dev/null 2>&1 || fail "tar is required"

java_major() {
  "$1" -version 2>&1 | sed -n \
    -e 's/.*version "1\.\([0-9][0-9]*\).*/\1/p' \
    -e 's/.*version "\([0-9][0-9]*\).*/\1/p' \
    -e 's/^[^ ][^ ]* \([0-9][0-9]*\)\([. ].*\)\{0,1\}$/\1/p' |
    sed -n '1p'
}

check_java() {
  java_cmd="$1"
  java_source="$2"
  java_version="$(java_major "$java_cmd")" || fail "Java 21 or newer is required, but $java_source could not be executed"
  [ -n "$java_version" ] || fail "Java 21 or newer is required, but the version from $java_source could not be parsed"
  [ "$java_version" -ge 21 ] || fail "Java 21 or newer is required; $java_source is Java $java_version"
}

if [ -n "${JAVA_HOME:-}" ]; then
  if [ -x "$JAVA_HOME/jre/sh/java" ]; then
    check_java "$JAVA_HOME/jre/sh/java" "JAVA_HOME ($JAVA_HOME)"
  elif [ -x "$JAVA_HOME/bin/java" ]; then
    check_java "$JAVA_HOME/bin/java" "JAVA_HOME ($JAVA_HOME)"
  else
    fail "Java 21 or newer is required, but JAVA_HOME does not point to a valid Java install: $JAVA_HOME"
  fi
elif command -v java >/dev/null 2>&1; then
  check_java "$(command -v java)" "java on PATH ($(command -v java))"
else
  fail "Java 21 or newer is required. Install Java 21+ or set JAVA_HOME to a Java 21+ install."
fi

if [ "$version" = "latest" ]; then
  url="https://github.com/${repo}/releases/latest/download/pl.tar"
else
  case "$version" in
    v*) tag="$version" ;;
    *) tag="v$version" ;;
  esac
  url="https://github.com/${repo}/releases/download/${tag}/pl.tar"
fi

tmp_dir="$(mktemp -d)"
trap 'rm -rf "$tmp_dir"' EXIT HUP INT TERM

archive="$tmp_dir/pl.tar"

printf 'Downloading %s\n' "$url"
curl -fsSL "$url" -o "$archive"

rm -rf "$install_root"
mkdir -p "$install_root" "$bin_dir"
tar -xf "$archive" -C "$install_root" --strip-components=1
ln -sfn "$install_root/bin/pl" "$bin_dir/pl"

printf 'Installed pl -> %s/pl\n' "$bin_dir"
case ":$PATH:" in
  *":$bin_dir:"*) ;;
  *) printf 'Add %s to your PATH to run pl from any terminal.\n' "$bin_dir" ;;
esac
